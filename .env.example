# =============================================================================
# CS-CloudflareTunnel — Environment Example
# =============================================================================
# Copy to `.env` and fill in the secrets. `.env` is git-ignored.
#   cp .env.example .env
# =============================================================================

# ── Image selection ─────────────────────────────────────────────────────────
# BAUER GROUP edition (cloudflared + built-in /ready healthcheck).
CLOUDFLARED_IMAGE=ghcr.io/bauer-group/cs-cloudflaretunnel/cloudflared
CLOUDFLARED_VERSION=latest

# ── Stack / runtime ─────────────────────────────────────────────────────────
STACK_NAME=cloudflare-tunnel
TIME_ZONE=Etc/UTC

# ── Cloudflare Tunnel (remote-managed / token mode) ─────────────────────────
# Zero Trust → Networks → Tunnels → Create tunnel (Cloudflared) → copy the token.
# Read from the environment (not argv), so it is not visible in `ps` / logs.
TUNNEL_TOKEN=eyJ...replace-me...

# ── Health probe (optional override) ────────────────────────────────────────
# The image probes http://127.0.0.1:2000/ready by default. Override only if you
# change the metrics address in the container command.
# HEALTHPROBE_URL=http://127.0.0.1:2000/ready
