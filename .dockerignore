# =============================================================================
# Docker build-context exclusions (repo root)
# =============================================================================
# The image is built from ./src/cloudflared (see docker-context in CI), so this
# root .dockerignore only matters for ad-hoc `docker build .` from the repo root.

.git
.github
.gitignore
.gitattributes

# Documentation isn't needed in the image
docs
*.md

# Compose files are read by `docker compose`, not by `docker build`
docker-compose*.yml

# Host secrets — never copy into image layers
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor temp
*.tmp
*.bak
*.swp
.vscode
.idea
