# =============================================================================
# Line-ending normalization
# =============================================================================
# Without this file, Windows checkouts default to CRLF, which silently breaks
# POSIX-sh heredocs inside Dockerfile RUN blocks and corrupts shell tokens.
# Enforce LF for everything that the container-side toolchain executes.
# =============================================================================

# Default: let git auto-detect text vs binary, normalize to LF on commit
*               text=auto eol=lf

# Files that MUST be LF inside the container image / build pipeline.
Dockerfile      text eol=lf
*.sh            text eol=lf
*.env           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.go            text eol=lf
*.mod           text eol=lf
*.json          text eol=lf

# Binary assets — never normalize
*.png           binary
*.jpg           binary
*.jpeg          binary
*.webp          binary
*.ico           binary
